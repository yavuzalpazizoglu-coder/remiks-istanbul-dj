# Sunucu Portu (Railway/Render genelde PORT’u otomatik verir)
PORT=3000

# Üretim: npm start bunu ayarlar. Elle node server.js kullanıyorsanız:
# NODE_ENV=production

# Ters vekil (Railway, Render, Fly) arkasında gerçek istemci IP’si için; rate limit doğru çalışsın.
# Yerelde veya doğrudan IP ile testte: TRUST_PROXY=0
TRUST_PROXY=1

# DJ Panel Şifresi (etkinlik oluştururken kullanılır)
DJ_PASSWORD=remiks2026

# Spotify API (isteğe bağlı - şarkı arama + kapak fotoğrafı için)
# https://developer.spotify.com/dashboard adresinden alınır
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Uygulama kökeni (CORS + Socket.io). Üretimde tam HTTPS URL şart.
# Yerelde: http://localhost:3000 veya Vite proxy kullanıyorsanız http://localhost:5173
# Bulutta: https://your-app.railway.app (sonunda / olmadan)
APP_URL=http://localhost:3000

# Etkinlik Sonu Rapor Maili (Gmail App Password)
# Gmail → Google Hesabım → Güvenlik → 2FA açık → Uygulama Şifreleri
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Raporun gönderileceği mail adresleri (virgülle ayır)
REPORT_TO_EMAILS=admin@example.com,diger@example.com
